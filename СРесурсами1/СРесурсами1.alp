								<Code><![CDATA[Math.max(uniform(0, 365 * Math.max(unit.здоровье, 0.05)), 1)
]]></Code>
								<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[timeBetweenFailures]]></Name>
							<Value Class="CodeUnitValue">
								<Code><![CDATA[((Работник)unit).текущийПростойАбсентеизм
    ? uniform(30, 90)
    : Math.max(triangularAV(365 * Math.max(unit.здоровье, 0.05) * 0.95, 0.1 * Math.max(unit.здоровье, 0.05)), 1)]]></Code>
								<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[countBusyOnlyTimeToFailure]]></Name>
						</Parameter>
