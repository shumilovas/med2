					<Id>1779889391545</Id>
					<Name><![CDATA[рассчитатьПремиюЗаФизическуюАктивность]]></Name>
					<X>460</X><Y>410</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[if (участвуетВПрограмме && уровеньАктивности > 0) {
        double годоваяПремия = main.базовыйРазмерГодовойПремииЗаФизическуюАктивность;
        double периодВыплат = main.периодичностьВыплатПремииЗаФизАктивность;
        премияЗаАктивность = годоваяПремия / периодВыплат;
        return годоваяПремия / периодВыплат;
    } else {
        премияЗаАктивность = 0;
        return 0;
    }]]></Body>
				</Function>
			</Functions>
