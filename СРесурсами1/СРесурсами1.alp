							<Code><![CDATA[частотаБольничных]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[ктоБолеет = uniform_discr(1, 5);
if (ктоБолеет == 1) болезнь1.block();
if (ктоБолеет == 2) болезнь2.block();
if (ктоБолеет == 3) болезнь3.block();
if (ктоБолеет == 4) болезнь4.block();
if (ктоБолеет == 5) болезнь5.block();
]]></Action>
