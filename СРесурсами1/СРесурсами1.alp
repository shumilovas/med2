						</Rate>
						<Id>1775594879995</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1774339200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[800]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (РаботаетЛиСистемаЗдравосохранения==true) 
	{
	for (int i=0; i<работники.size(); i++)
		работники.get(i).здоровье +=0.2;
	if (длительностьБолезни>5) длительностьБолезни -=5;
	}]]></Action>
				</Event>
				<Event>
					<Id>1776342362641</Id>
					<Name><![CDATA[НазначаемИзначальноеЗдоровье]]></Name>
					<X>660</X><Y>500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1775594879994</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773820800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[for (int i = 0; i<работники.size() ; i++) 
	{
	работники.get(i).здоровье = triangular(0.3, 1.3, 0.8);
	traceln("rabotnik = " +i);
	работники.get(i).продуктивность = triangular(0.3, 1.3, 0.8);
	}
]]></Action>
				</Event>
