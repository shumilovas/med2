			<Events>
				<Event>
					<Id>1776342253410</Id>
					<Name><![CDATA[ПрограммаЗдравосохранения]]></Name>
					<X>498</X><Y>285</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1775594879994</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1774339200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[800]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (РаботаетЛиСистемаЗдравосохранения==true) 
{
    for (int i=0; i<работники.size(); i++)
        работники.get(i).здоровье = Math.min(работники.get(i).здоровье + 0.2, 2.3);
    if (длительностьБолезни>5) длительностьБолезни -=5;
}]]></Action>
				</Event>
				<Event>
					<Id>1776342362641</Id>
					<Name><![CDATA[НазначаемИзначальноеЗдоровьеИПсихотипы]]></Name>
					<X>660</X><Y>500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1775594879993</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773820800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[for (int i = 0; i < работники.size(); i++) {
    работники.get(i).здоровье = triangular(0.3, 1.3, 0.8);
    работники.get(i).продуктивность = triangular(0.3, 1.3, 0.8);
    работники.get(i).когдаВзятНаРаботу = -uniform(0, 365);
    
    работники.get(i).уровеньАктивности = 0;
    работники.get(i).премияЗаАктивность = 0;
    работники.get(i).участвуетВПрограмме = uniform() < 0.5;//учавствует ли работник в программе премирования физ активности
    работники.get(i).рассчитатьПремиюЗаФизическуюАктивность(); // инициализируем начальное значение

    double rand = uniform(0, 1);
    if      (rand < 0.20) работники.get(i).психотип = 1;
    else if (rand < 0.40) работники.get(i).психотип = 2;
    else if (rand < 0.60) работники.get(i).психотип = 3;
    else if (rand < 0.75) работники.get(i).психотип = 4;
    else                  работники.get(i).психотип = 5;

    if      (работники.get(i).психотип == 1) работники.get(i).психиатрическийПсихотип = ПсихиатрическиеПсихотипы.шизоид;
    else if (работники.get(i).психотип == 2) работники.get(i).психиатрическийПсихотип = ПсихиатрическиеПсихотипы.эпилептоид;
    else if (работники.get(i).психотип == 3) работники.get(i).психиатрическийПсихотип = ПсихиатрическиеПсихотипы.гипертим;
    else if (работники.get(i).психотип == 4) работники.get(i).психиатрическийПсихотип = ПсихиатрическиеПсихотипы.истероид;
    else                                      работники.get(i).психиатрическийПсихотип = ПсихиатрическиеПсихотипы.нормотим;

    Работник рр = работники.get(i);

    if      (рр.психотип == 1) {
        рр.экстраверсия   = triangular(0.0,  0.45, 0.2);
        рр.интуиция       = triangular(0.55, 1.0,  0.8);
        рр.логика         = triangular(0.5,  1.0,  0.75);
        рр.рациональность = triangular(0.2,  0.7,  0.45);
        рр.доминантность  = triangular(0.0,  0.4,  0.15);
    } else if (рр.психотип == 2) {
        рр.экстраверсия   = triangular(0.3,  0.7,  0.5);
        рр.интуиция       = triangular(0.0,  0.45, 0.2);
        рр.логика         = triangular(0.6,  1.0,  0.8);
        рр.рациональность = triangular(0.65, 1.0,  0.85);
        рр.доминантность  = triangular(0.3,  0.75, 0.55);
    } else if (рр.психотип == 3) {
        рр.экстраверсия   = triangular(0.65, 1.0,  0.85);
        рр.интуиция       = triangular(0.3,  0.7,  0.5);
        рр.логика         = triangular(0.3,  0.7,  0.5);
        рр.рациональность = triangular(0.1,  0.55, 0.3);
        рр.доминантность  = triangular(0.5,  1.0,  0.75);
    } else if (рр.психотип == 4) {
        рр.экстраверсия   = triangular(0.6,  1.0,  0.8);
        рр.интуиция       = triangular(0.3,  0.7,  0.5);
        рр.логика         = triangular(0.0,  0.45, 0.2);
        рр.рациональность = triangular(0.1,  0.6,  0.35);
        рр.доминантность  = triangular(0.2,  0.65, 0.4);
    } else {
        рр.экстраверсия   = triangular(0.3,  0.7,  0.5);
        рр.интуиция       = triangular(0.3,  0.7,  0.5);
        рр.логика         = triangular(0.3,  0.7,  0.5);
        рр.рациональность = triangular(0.3,  0.7,  0.5);
        рр.доминантность  = triangular(0.2,  0.6,  0.4);
    }

    boolean e = рр.экстраверсия   > 0.5;
    boolean n = рр.интуиция       > 0.5;
    boolean t = рр.логика         > 0.5;
    boolean j = рр.рациональность > 0.5;

    if      ( e &&  n &&  t &&  j) { рр.mbti = ТипМБТИ.ENTJ; рр.соционика = ТипСоционика.Джек; }
    else if ( e &&  n &&  t && !j) { рр.mbti = ТипМБТИ.ENTP; рр.соционика = ТипСоционика.ДонКихот; }
    else if ( e &&  n && !t &&  j) { рр.mbti = ТипМБТИ.ENFJ; рр.соционика = ТипСоционика.Гамлет; }
    else if ( e &&  n && !t && !j) { рр.mbti = ТипМБТИ.ENFP; рр.соционика = ТипСоционика.Гексли; }
    else if ( e && !n &&  t &&  j) { рр.mbti = ТипМБТИ.ESTJ; рр.соционика = ТипСоционика.Жуков; }
    else if ( e && !n &&  t && !j) { рр.mbti = ТипМБТИ.ESTP; рр.соционика = ТипСоционика.Штирлиц; }
    else if ( e && !n && !t &&  j) { рр.mbti = ТипМБТИ.ESFJ; рр.соционика = ТипСоционика.Гюго; }
    else if ( e && !n && !t && !j) { рр.mbti = ТипМБТИ.ESFP; рр.соционика = ТипСоционика.Наполеон; }
    else if (!e &&  n &&  t &&  j) { рр.mbti = ТипМБТИ.INTJ; рр.соционика = ТипСоционика.Робеспьер; }
    else if (!e &&  n &&  t && !j) { рр.mbti = ТипМБТИ.INTP; рр.соционика = ТипСоционика.Бальзак; }
    else if (!e &&  n && !t &&  j) { рр.mbti = ТипМБТИ.INFJ; рр.соционика = ТипСоционика.Достоевский; }
    else if (!e &&  n && !t && !j) { рр.mbti = ТипМБТИ.INFP; рр.соционика = ТипСоционика.Есенин; }
    else if (!e && !n &&  t &&  j) { рр.mbti = ТипМБТИ.ISTJ; рр.соционика = ТипСоционика.Максим; }
    else if (!e && !n &&  t && !j) { рр.mbti = ТипМБТИ.ISTP; рр.соционика = ТипСоционика.Габен; }
    else if (!e && !n && !t &&  j) { рр.mbti = ТипМБТИ.ISFJ; рр.соционика = ТипСоционика.Драйзер; }
    else                            { рр.mbti = ТипМБТИ.ISFP; рр.соционика = ТипСоционика.Дюма; }
}]]></Action>
				</Event>
				<Event>
					<Id>1777580580674</Id>
					<Name><![CDATA[суммаЗарплатИБольничныхСобытие]]></Name>
					<X>280</X><Y>480</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1775594879992</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1774080000000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[10]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[суммаЗарплат = 0;
суммаБольничных = 0;
int кБольных = 0;
int кВыгоревших = 0;
for(int i = 0; i < работники.size(); i++) {
    суммаЗарплат += работники.get(i).суммаЗарплат;
    суммаБольничных += работники.get(i).суммаБольничных;
    if (работники.get(i).участвуетВПрограмме) {
                работники.get(i).уровеньАктивности +=0.01;
            }
    if (работники.get(i).inState(работники.get(i).заболел)) кБольных++;
    if (работники.get(i).inState(работники.get(i).перегорает)) кВыгоревших++;
}
// Прирост выручки за цикл (ПОСЛЕ сбора данных)
выручкаЗаЦикл = суммаВыручки - предыдущаяВыручка;
предыдущаяВыручка = суммаВыручки;
бюджетНаЗарплаты = суммаВыручки * 0.001;
// Передача данных в агент Экономика
экономика.суммаВыручки = суммаВыручки;
экономика.суммаЗарплат = суммаЗарплат;
экономика.суммаБольничных = суммаБольничных;
экономика.суммаЗатратНаСырьё = суммаЗатратНаСырьё;
экономика.суммаЗатратНаПрограмму = суммаЗатратНаПрограммуВсего;
// Обновление SD-слоя
if (работники.size() > 0) {
    индексБолезни = (double) кБольных / работники.size();
    индексВыгорания = (double) кВыгоревших / работники.size();
    кадроваяНагрузка = 1.0 / Math.max(1.0 - индексВыгорания - индексБолезни, 0.1);
} else {
    индексБолезни = 0; индексВыгорания = 0; кадроваяНагрузка = 1.0;
}
стоимостьПрограммы = РаботаетЛиСистемаЗдравосохранения ? количествоРаботников * 50.0 : 0.0;
ROI = суммаЗатратНаПрограммуВсего > 0 ? (суммаВыручки - экономика.ЗатратыНаПерсонал - экономика.ЗатратыНаСырьё - суммаЗатратНаПрограммуВсего) / суммаЗатратНаПрограммуВсего * 100 : 0;
экономика.ROI = ROI;
// Обновляем расчётные переменные пищеблока
количествоРаботниковРекомендуемое = Math.ceil(экономика.рынок * 5.0 / 150.0 / 5.0);
площадьПроизводства    = количествоРаботниковРекомендуемое * 8.0;
площадьОбеденногоЗала  = экономика.рынок * 1.25 / 2.0;
площадьСклада          = экономика.рынок * 5 * 0.003 * 3;
объёмХолодильников     = экономика.рынок * 5 * 0.4 * 0.0015 * 3;
площадьЗоныОтдыха      = количествоРаботниковРекомендуемое * 0.9 * кадроваяНагрузка;
мощностьВытяжки        = Math.min(количествоРаботниковРекомендуемое, 4) * 5000 * кадроваяНагрузка;
бюджетНаПерсоналФакт   = суммаЗарплат + суммаБольничных;]]></Action>
				</Event>
				<Event>
					<Id>1779301220065</Id>
					<Name><![CDATA[ЕстественноеСнижениеЗдоровья]]></Name>
					<X>600</X><Y>350</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<Id>1775594879991</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1774339200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[400]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (!РаботаетЛиСистемаЗдравосохранения) 
	{
	for (int i=0; i<работники.size(); i++)
		работники.get(i).здоровье = Math.max(работники.get(i).здоровье - 0.05, 0.05);
	if (длительностьБолезни>5) длительностьБолезни +=1;
	} else {
	// Программа здравоохранения: частичный сброс усталости (восстановление)
	for (int i=0; i<работники.size(); i++) {
		работники.get(i).накопленнаяУсталость = 
			Math.max(работники.get(i).накопленнаяУсталость - 0.5, 0);
	}
	}]]></Action>
				</Event>
				<Event>
					<Id>1779473638282</Id>
					<Name><![CDATA[увольнение]]></Name>
					<X>90</X><Y>90</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1775594879990</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1779523200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[10]]></Code>
							<Unit Class="TimeUnits"><![CDATA[WEEK]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1.5]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[double бюджетСБуфером = бюджетНаЗарплаты * 0.9;
double максЗарплата = 7500;
double общаяСуммаЗарплат = 0;
double средняяЗарплата = 0;

for (int i = работники.size()-1; i >= 0; i--) {
    Работник р = работники.get(i);
    
    общаяСуммаЗарплат = 0;
    for (Работник раб : работники) общаяСуммаЗарплат += раб.зарплата;
    средняяЗарплата = общаяСуммаЗарплат / работники.size();
    
    // Высокопродуктивные — уходят сами после 1.5 лет
    if ((time() - р.когдаВзятНаРаботу > 545) && (р.продуктивность > 0.7)) {
        double коэффициент = uniform(1.03, 1.12);
        double новаяЗарплата = р.зарплата * коэффициент;
        
        if ((общаяСуммаЗарплат - р.зарплата + новаяЗарплата <= бюджетСБуфером) &&
            (новаяЗарплата <= максЗарплата)) {
            р.зарплата = новаяЗарплата;
            общаяСуммаЗарплат = 0;
            for (Работник раб : работники) общаяСуммаЗарплат += раб.зарплата;
            средняяЗарплата = общаяСуммаЗарплат / работники.size();
            
        } else if (новаяЗарплата > максЗарплата) {
           
            remove_работники(р);
            задержкаНайма.restartTo(time() + uniform(60, 90));
        } else if (р.зарплата > 2700) {
            
            remove_работники(р);
            задержкаНайма.restartTo(time() + uniform(60, 90));
        } else {
           
        }
    }
    // Низкопродуктивные — увольняем принудительно, долго и редко
    else if ((time() - р.когдаВзятНаРаботу > 730) && 
             (р.продуктивность < 0.3) && 
             (р.здоровье < 0.4)) {
        
        remove_работники(р);
        задержкаНайма.restartTo(time() + uniform(90, 180));
    }
}]]></Action>
				</Event>
