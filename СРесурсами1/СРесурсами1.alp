						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1775594879968</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1779955200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (участвуетВПрограмме && уровеньАктивности > 0) {
        double годоваяПремия = main.базовыйРазмерГодовойПремииЗаФизическуюАктивность;
        double периодВыплат = main.периодичностьВыплатПремииЗаФизАктивность;
        премияЗаАктивность = годоваяПремия / периодВыплат;
       
    } else {
        премияЗаАктивность = 0;
      
    }]]></Action>
				</Event>
				<Event>
					<Id>1779901770946</Id>
					<Name><![CDATA[пересчетПроизводительностиПриВыгорании]]></Name>
					<X>290</X><Y>520</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1775594879967</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1779955200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[2]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (накопленнаяУсталость > 25) {
    double доляПотерьОтБолезней = (суммаЗарплат > 0)
        ? Math.min(суммаБольничных / суммаЗарплат, 0.5)
        : 0;
    double новаяПродуктивность = продуктивность
        * (1 - накопленнаяУсталость / 100)
        * здоровье
        * (1 - доляПотерьОтБолезней);
    продуктивность = Math.max(новаяПродуктивность, 0.05);
}]]></Action>
				</Event>
				<Event>
					<Id>1779903991614</Id>
					<Name><![CDATA[обновитьСостояние]]></Name>
					<X>60</X><Y>340</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1775594879966</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1779955200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[19]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[10]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[// Влияние здоровья на накопление усталости
        if (здоровье > 0.85) {
            коэффициентУтомления = 0.95;
        } else if (здоровье < 0.70) {
            коэффициентУтомления = 1.03;
        } else {
            коэффициентУтомления = 1.0;
        }

        // Влияние усталости на здоровье (нижняя граница 0.05)
        if (накопленнаяУсталость > 20) {
            здоровье = Math.max(здоровье - 0.5, 0.05);
        } else if (накопленнаяУсталость > 15) {
            здоровье = Math.max(здоровье - 0.2, 0.05);
        }]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
