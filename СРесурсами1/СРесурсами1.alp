						<Parameter>
							<Name><![CDATA[onMaintenanceStart]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Работник р = (Работник)unit;
// Зачисляем стоимость спортзала напрямую в Main
if (РаботаетЛиСистемаЗдравосохранения) {
    суммаЗатратНаПрограммуВсего += базовыйРазмерГодовойПремииЗаФизическуюАктивность / периодичностьВыплатПремииЗаФизАктивность;
    // Улучшаем здоровье при посещении спортзала
    р.здоровье = Math.min(р.здоровье + 0.01, 2.3);
}]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onMaintenanceEnd]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onFailure]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Работник р = (Работник)unit;
// Флаг уже установлен в onRepair предыдущего цикла
if (!р.текущийПростойАбсентеизм) {
    р.больничНачало = time();
    send("заболей", р);
} else {
}
]]></Code>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[onRepair]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Работник р = (Работник)unit;
if (!р.текущийПростойАбсентеизм) {
    send("выздоровел", р);
    р.больничКонец = time();
    р.суммаБольничных += (р.больничКонец - р.больничНачало) * 24 * р.зарплата * коэффециэнтДляБольничных;
} else {
}
// Устанавливаем тип СЛЕДУЮЩЕГО простоя — здесь, чтобы repairTime его прочитал
р.текущийПростойАбсентеизм = р.absenteeismProbability > uniform(0, 1);
]]></Code>
							</Value>
						</Parameter>
