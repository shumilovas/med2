				<Event>
					<Id>1779889843360</Id>
					<Name><![CDATA[РасчетПремийЗаФизАктив]]></Name>
					<X>50</X><Y>500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>false</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1775594879988</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1779955200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MONTH]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[365/периодичностьВыплатПремииЗаФизАктивность]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[
        if (системаПРемированияЗаФизАктивность) {
            double общаяСуммаПремий = 0;
            
            for (Работник r : работники) {
                r.рассчитатьПремиюЗаФизическуюАктивность(); // рассчитываем премию внутри работника
                общаяСуммаПремий += r.премияЗаАктивность;
            }
            
            суммаЗарплат += общаяСуммаПремий;
            
        }
]]></Action>
				</Event>
			</Events>
			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1781864569361</Id>
					<Name><![CDATA[validateLayout]]></Name>
					<X>180</X><Y>1160</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// 1. Масштаб: 1 единица AnyLogic = 0.01 метра (1 см)
double scaleFactor = 0.01; 

// 2. Коэффициент коррекции: умножаем итоговое расстояние в метрах на 3
double correctionCoefficient = 3.0;

// 3. Получаем узлы (убедись, что имена совпадают с именами на схеме!)
Node nodeServing = раздаточная;      // узел раздачи
Node nodeDining = ОбеденныйЗал;     // узел обеденного зала

// 4. Проверка на null (чтобы не было ошибки, если узел не найден)
if (nodeServing == null || nodeDining == null) {
    traceln("ОШИБКА: Узлы не назначены! Проверь имена переменных в свойствах агента Main.");
    return;
}

// 5. Считаем расстояние в единицах AnyLogic (ОДИН РАЗ!)
double distanceUnits = Utilities.getDistance(
    getNodeX(nodeServing), 
    getNodeY(nodeServing), 
    getNodeX(nodeDining), 
    getNodeY(nodeDining)
);

// 6. Переводим в метры с учётом коэффициента коррекции
double distanceMeters = distanceUnits * scaleFactor * correctionCoefficient;

// 7. Лимит теперь ставим в МЕТРАХ (с учётом того, что расстояние уже утроено)
double maxAllowedDistanceMeters = 50.0; 

// 8. Вывод основных результатов в консоль
traceln("Расстояние в единицах AnyLogic: " + distanceUnits);
traceln("Расстояние в метрах (с коэффициентом x3): " + distanceMeters + " м");


// 10. Выводим гипотенузу (используем УЖЕ ПОСЧИТАННУЮ переменную distanceUnits)
traceln("Гипотенуза (прямое расстояние): " + distanceUnits + " ед.");
traceln("----------------------");

// 11. Проверка лимита
if (distanceMeters > maxAllowedDistanceMeters) {
    traceln("ПРЕДУПРЕЖДЕНИЕ: Расстояние слишком большое: " + distanceMeters + " м. Лимит: " + maxAllowedDistanceMeters + " м.");
} else {
    traceln("Маршрут валиден. Расстояние: " + distanceMeters + " м.");
}
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1781882074936</Id>
					<Name><![CDATA[getNodeX]]></Name>
					<X>300</X><Y>1170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[n]]></Name>
						<Type><![CDATA[Node]]></Type>
					</Parameter>
					<Body><![CDATA[if (n == null) return 0;
    
    // Проверяем тип узла и получаем координаты
    if (n instanceof RectangularNode) {
        return ((RectangularNode) n).getX();
    } else if (n instanceof PointNode) {
        return ((PointNode) n).getX();
    }
    return 0;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1781882904570</Id>
					<Name><![CDATA[getNodeY]]></Name>
					<X>300</X><Y>1170</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[n]]></Name>
						<Type><![CDATA[Node]]></Type>
					</Parameter>
					<Body><![CDATA[if (n == null) return 0;
    
    // Проверяем тип узла и получаем координаты
    if (n instanceof RectangularNode) {
        return ((RectangularNode) n).getY();
    } else if (n instanceof PointNode) {
        return ((PointNode) n).getY();
    }
    return 0;]]></Body>
				</Function>
