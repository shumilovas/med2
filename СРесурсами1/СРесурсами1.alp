							<Value Class="CodeUnitValue">
								<Code><![CDATA[Math.max(uniform(0, 365*unit.здоровье), 1)
]]></Code>
								<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
							</Value>
						</Parameter>
						<Parameter>
							<Name><![CDATA[timeBetweenFailures]]></Name>
							<Value Class="CodeUnitValue">
								<Code><![CDATA[Math.max(triangularAV(365*unit.здоровье*0.95, 0.1*unit.здоровье), 1)]]></Code>
								<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
							</Value>
