				<Event>
					<Id>1776342253410</Id>
					<Name><![CDATA[ПрограммаЗдравосохранения]]></Name>
					<X>498</X><Y>285</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1774339200000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[0]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[800]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[if (РаботаетЛиСистемаЗдравосохранения==true) 
{
    for (int i=0; i<работники.size(); i++)
        работники.get(i).здоровье = Math.min(работники.get(i).здоровье + 0.2, 2.3);
    if (длительностьБолезни>5) длительностьБолезни -=5;
}]]></Action>
				</Event>
				<Event>
					<Id>1776342362641</Id>
					<Name><![CDATA[НазначаемИзначальноеЗдоровьеИПсихотипы]]></Name>
					<X>660</X><Y>500</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="timeout" Mode="occuresOnce">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_HOUR]]></Unit>
						</Rate>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1773820800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[for (int i = 0; i < работники.size(); i++) {
    работники.get(i).здоровье = triangular(0.3, 1.3, 0.8);
    работники.get(i).продуктивность = triangular(0.3, 1.3, 0.8);
    работники.get(i).когдаВзятНаРаботу = -uniform(0, 365);

    double rand = uniform(0, 1);
    if      (rand < 0.20) работники.get(i).психотип = 1;
    else if (rand < 0.40) работники.get(i).психотип = 2;
    else if (rand < 0.60) работники.get(i).психотип = 3;
    else if (rand < 0.75) работники.get(i).психотип = 4;
    else                  работники.get(i).психотип = 5;

    Работник рр = работники.get(i);

    if      (рр.психотип == 1) {
        рр.экстраверсия   = triangular(0.0,  0.45, 0.2);
        рр.интуиция       = triangular(0.55, 1.0,  0.8);
        рр.логика         = triangular(0.5,  1.0,  0.75);
        рр.рациональность = triangular(0.2,  0.7,  0.45);
        рр.доминантность  = triangular(0.0,  0.4,  0.15);
    } else if (рр.психотип == 2) {
        рр.экстраверсия   = triangular(0.3,  0.7,  0.5);
        рр.интуиция       = triangular(0.0,  0.45, 0.2);
        рр.логика         = triangular(0.6,  1.0,  0.8);
        рр.рациональность = triangular(0.65, 1.0,  0.85);
        рр.доминантность  = triangular(0.3,  0.75, 0.55);
    } else if (рр.психотип == 3) {
        рр.экстраверсия   = triangular(0.65, 1.0,  0.85);
        рр.интуиция       = triangular(0.3,  0.7,  0.5);
        рр.логика         = triangular(0.3,  0.7,  0.5);
        рр.рациональность = triangular(0.1,  0.55, 0.3);
        рр.доминантность  = triangular(0.5,  1.0,  0.75);
    } else if (рр.психотип == 4) {
        рр.экстраверсия   = triangular(0.6,  1.0,  0.8);
        рр.интуиция       = triangular(0.3,  0.7,  0.5);
        рр.логика         = triangular(0.0,  0.45, 0.2);
        рр.рациональность = triangular(0.1,  0.6,  0.35);
        рр.доминантность  = triangular(0.2,  0.65, 0.4);
    } else {
        рр.экстраверсия   = triangular(0.3,  0.7,  0.5);
        рр.интуиция       = triangular(0.3,  0.7,  0.5);
        рр.логика         = triangular(0.3,  0.7,  0.5);
        рр.рациональность = triangular(0.3,  0.7,  0.5);
        рр.доминантность  = triangular(0.2,  0.6,  0.4);
    }

    boolean e = рр.экстраверсия   > 0.5;
    boolean n = рр.интуиция       > 0.5;
    boolean t = рр.логика         > 0.5;
    boolean j = рр.рациональность > 0.5;

    if      ( e &&  n &&  t &&  j) { рр.mbti = ТипМБТИ.ENTJ; рр.соционика = ТипСоционика.Джек; }
    else if ( e &&  n &&  t && !j) { рр.mbti = ТипМБТИ.ENTP; рр.соционика = ТипСоционика.ДонКихот; }
    else if ( e &&  n && !t &&  j) { рр.mbti = ТипМБТИ.ENFJ; рр.соционика = ТипСоционика.Гамлет; }
    else if ( e &&  n && !t && !j) { рр.mbti = ТипМБТИ.ENFP; рр.соционика = ТипСоционика.Гексли; }
    else if ( e && !n &&  t &&  j) { рр.mbti = ТипМБТИ.ESTJ; рр.соционика = ТипСоционика.Жуков; }
    else if ( e && !n &&  t && !j) { рр.mbti = ТипМБТИ.ESTP; рр.соционика = ТипСоционика.Штирлиц; }
    else if ( e && !n && !t &&  j) { рр.mbti = ТипМБТИ.ESFJ; рр.соционика = ТипСоционика.Гюго; }
    else if ( e && !n && !t && !j) { рр.mbti = ТипМБТИ.ESFP; рр.соционика = ТипСоционика.Наполеон; }
    else if (!e &&  n &&  t &&  j) { рр.mbti = ТипМБТИ.INTJ; рр.соционика = ТипСоционика.Робеспьер; }
    else if (!e &&  n &&  t && !j) { рр.mbti = ТипМБТИ.INTP; рр.соционика = ТипСоционика.Бальзак; }
    else if (!e &&  n && !t &&  j) { рр.mbti = ТипМБТИ.INFJ; рр.соционика = ТипСоционика.Достоевский; }
    else if (!e &&  n && !t && !j) { рр.mbti = ТипМБТИ.INFP; рр.соционика = ТипСоционика.Есенин; }
    else if (!e && !n &&  t &&  j) { рр.mbti = ТипМБТИ.ISTJ; рр.соционика = ТипСоционика.Максим; }
    else if (!e && !n &&  t && !j) { рр.mbti = ТипМБТИ.ISTP; рр.соционика = ТипСоционика.Габен; }
    else if (!e && !n && !t &&  j) { рр.mbti = ТипМБТИ.ISFJ; рр.соционика = ТипСоционика.Драйзер; }
    else                            { рр.mbti = ТипМБТИ.ISFP; рр.соционика = ТипСоционика.Дюма; }
}]]></Action>
				</Event>
				<Event>
