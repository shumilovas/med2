						<Parameter>
							<Name><![CDATA[onPrepareUnit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[Работник работник = (Работник)unit;

// базовое время выполнения
agent.назначенноеВремяДэлэйПоДанномуСотруднику = Math.max(
    0.105 * agent.сложность / (Math.max(работник.продуктивность, 0.01) * Math.max(работник.здоровье, 0.01)),
    0.1);

// совпадение психотипа с типом задания
boolean совпадение =
    (работник.психотип == 1 && agent.типЗадания == ТипЗадания.аналитическое) ||
    (работник.психотип == 2 && agent.типЗадания == ТипЗадания.регламентное)  ||
    (работник.психотип == 3 && agent.типЗадания == ТипЗадания.управленческое)||
    (работник.психотип == 4 && agent.типЗадания == ТипЗадания.творческое);

if (совпадение) {
    agent.назначенноеВремяДэлэйПоДанномуСотруднику *= 0.7; // быстрее
    работник.накопленнаяУсталость -= 0.05; // усталость снижается
    работник.накопленнаяУсталость = Math.max(работник.накопленнаяУсталость, 0);
} else {
    agent.назначенноеВремяДэлэйПоДанномуСотруднику *= 1.3; // медленнее
    работник.накопленнаяУсталость += 0.1; // усталость растёт
}
]]></Code>
							</Value>
						</Parameter>
