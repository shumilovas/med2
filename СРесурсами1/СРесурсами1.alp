	работники.get(0).здоровье +=0.2;
	работники.get(1).здоровье +=0.2;
	работники.get(2).здоровье +=0.2;
	работники.get(3).здоровье +=0.2;
	работники.get(4).здоровье +=0.2;
	работники.get(5).здоровье +=0.2;
	if (длительностьБолезни>5) длительностьБолезни -=5;
	}]]></Action>
				</Event>
