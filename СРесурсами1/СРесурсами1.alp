							<Name><![CDATA[repairType]]></Name>
						</Parameter>
						<Parameter>
							<Name><![CDATA[repairTime]]></Name>
							<Value Class="CodeUnitValue">
								<Code><![CDATA[((Работник)unit).текущийПростойАбсентеизм
    ? uniform(1, 2)
    : Math.min(
        Math.max(triangularAV(2/Math.max(unit.здоровье, 0.05),
        0.5/Math.max(unit.здоровье, 0.05)), 0.01),
        30.0/7.0
      )]]></Code>
								<Unit Class="TimeUnits"><![CDATA[WEEK]]></Unit>
							</Value>
